      // Detect current month
      const hoy=new Date();const mes=hoy.getMonth();const anio=hoy.getFullYear();
      const mesNum=calcularMetasPeso(f.plan).findIndex(m=>{
        const d=new Date(m.mes.replace(/(\w+) (\d+)/,"1 $1 $2"));
        return d.getMonth()===mes&&d.getFullYear()===anio;
      });
      f.fotosBalanza.push({imagen:ev.target.result,fecha:new Date().toISOString(),mes:mesNum!==-1?mesNum+1:1});
      addPoints(f,20,false);checkAchievements(f);
      toast("⚖️ ¡Foto de balanza registrada! +20 pts");
      renderPerfil(panel,db.getCurrent(),f.plan);
    };r.readAsDataURL(e.target.files[0]);};inp.click();
  };

  document.getElementById("btnSubirFoto").onclick=()=>{
    const inp=document.createElement("input");inp.type="file";inp.accept="image/*";
    inp.onchange=e=>{const r=new FileReader();r.onload=ev=>{
      const f=db.getCurrent();if(!f.fotosProgreso)f.fotosProgreso=[];
      f.fotosProgreso.push({imagen:ev.target.result,fecha:new Date().toISOString()});
      addPoints(f,15,false);checkAchievements(f);
      toast("📸 Foto subida. +15 pts");
      renderPerfil(panel,db.getCurrent(),f.plan);
    };r.readAsDataURL(e.target.files[0]);};inp.click();
  };

  document.getElementById("btnReset").onclick=()=>{
    showModal(`<h3 style="font-family:'Syne',sans-serif;font-size:18px;margin-bottom:11px;">🔄 ¿Rehacer cuestionario?</h3>
      <p style="color:var(--text2);font-size:14px;margin-bottom:14px;">Tus puntos e historial se conservarán.</p>
      <div style="display:flex;gap:9px;">
        <button class="btn btn-secondary" style="flex:1;" onclick="this.closest('.modal-overlay').remove()">Cancelar</button>
        <button class="btn btn-primary" style="flex:1;" id="confReset">Confirmar</button>
      </div>`);
    setTimeout(()=>{
      document.getElementById("confReset").onclick=()=>{
        const f=db.getCurrent();f.plan=null;f.cuestionarioCompleto=false;saveUser(f);
        document.querySelector(".modal-overlay")?.remove();renderApp();
      };
    },50);
  };
  document.getElementById("btnOut").onclick=()=>{db.clearCurrent();renderApp()};
}

/* ═══════════════════════════════════════════════════
   INIT
═══════════════════════════════════════════════════ */
renderApp();
</script>
</body>
</html>
