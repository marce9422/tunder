function renderAsistente(panel,u,plan){
  if(chatHistory.length===0){
    chatHistory.push({role:"assistant",content:`¡Hola ${u.nombre||u.username}! 👋 Soy tu asistente basado en el Método Frank Suárez.\n\nSé que tu objetivo es **${plan.objetivo==='fat_loss'?'perder grasa':'ganar músculo'}** y tu sistema nervioso es **${plan.sistema}**. ¿En qué te ayudo hoy?`});
  }
  const renderMsgs=()=>chatHistory.map(m=>`
  <div class="msg-wrap ${m.role==='user'?'user':''}">
    <div class="msg-avatar ${m.role==='user'?'user':'bot'}">${m.role==='user'?'👤':'⚡'}</div>
    <div class="msg-bubble ${m.role==='user'?'user':'bot'}">${m.content.replace(/\n/g,'<br>').replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>')}</div>
  </div>`).join("");

  panel.innerHTML=`
  <div style="display:flex;flex-direction:column;gap:11px;">
    <div style="display:flex;align-items:center;justify-content:space-between;">
      <div class="section-title" style="margin-bottom:0;">🤖 Asistente IA</div>
      <div class="badge badge-green">Claude AI • En vivo</div>
    </div>
    <div class="chat-box" id="chatBox">${renderMsgs()}</div>
    <div class="chat-input-row">
      <input type="text" id="chatIn" placeholder="¿Qué comer después de entrenar?" autocomplete="off">
      <button class="btn btn-primary" id="btnSend" style="min-width:78px;">Enviar</button>
    </div>
    <div style="display:flex;gap:6px;flex-wrap:wrap;">
      ${["¿Cómo hacer la dieta 3x1?","¿Qué suplementos tomar?","¿Qué es el sistema nervioso pasivo?","Explica la Cándida","¿Cómo mejorar el sueño?"].map(q=>`<button class="btn btn-secondary btn-sm" style="font-size:12px;" onclick="document.getElementById('chatIn').value='${q}';document.getElementById('btnSend').click()">${q}</button>`).join("")}
    </div>
  </div>`;

  const cb=document.getElementById("chatBox");
  cb.scrollTop=cb.scrollHeight;

  const send=async()=>{
    const inp=document.getElementById("chatIn");
    const q=inp.value.trim();if(!q)return;
    inp.value="";
    chatHistory.push({role:"user",content:q});
    cb.innerHTML=renderMsgs();
    cb.innerHTML+=`<div class="msg-wrap" id="typing"><div class="msg-avatar bot">⚡</div><div class="msg-bubble bot"><div class="typing-dots"><span></span><span></span><span></span></div></div></div>`;
    cb.scrollTop=cb.scrollHeight;
    document.getElementById("btnSend").disabled=true;
    try{
      const sys=SYSTEM_PROMPT+`\n\nDatos del usuario: Objetivo: ${plan.objetivo==='fat_loss'?'pérdida de grasa':'ganancia muscular'}, Peso: ${plan.peso}kg, Altura: ${plan.altura}cm, IMC: ${plan.imc}, Sistema nervioso: ${plan.sistema}, Cándida: ${plan.candida}.`;
      const ans=await callClaude(chatHistory.slice(-8),sys);
      chatHistory.push({role:"assistant",content:ans});
    }catch{
      chatHistory.push({role:"assistant",content:"⚠️ Error de conexión. Intenta de nuevo."});
    }
    cb.innerHTML=renderMsgs();cb.scrollTop=cb.scrollHeight;
    document.getElementById("btnSend").disabled=false;
    document.getElementById("chatIn").focus();
  };
  document.getElementById("btnSend").onclick=send;
  document.getElementById("chatIn").addEventListener("keydown",e=>{if(e.key==="Enter")send()});
}

