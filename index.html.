        const stream=await navigator.mediaDevices.getUserMedia({video:{facingMode:"environment"},audio:false});
        const camModal=document.createElement("div");
        camModal.className="camera-modal";
        camModal.innerHTML=`
          <video id="camVideo" autoplay playsinline></video>
          <canvas id="camCanvas"></canvas>
          <div class="camera-controls">
            <button class="btn btn-danger btn-sm" id="btnCamClose" style="border-radius:99px;padding:12px 18px;"><i class="fas fa-times"></i> Cerrar</button>
            <button class="btn-capture" id="btnCamCapture"><i class="fas fa-camera"></i></button>
          </div>`;
        document.body.appendChild(camModal);
        const video=document.getElementById("camVideo");
        video.srcObject=stream;
        await video.play();

        document.getElementById("btnCamClose").onclick=()=>{
          stream.getTracks().forEach(t=>t.stop());
          camModal.remove();
        };
        document.getElementById("btnCamCapture").onclick=()=>{
          const canvas=document.getElementById("camCanvas");
          canvas.width=video.videoWidth;canvas.height=video.videoHeight;
          canvas.getContext("2d").drawImage(video,0,0);
          const dataUrl=canvas.toDataURL("image/jpeg",0.9);
          stream.getTracks().forEach(t=>t.stop());
          camModal.remove();
          scanState.file={};scanState.url=dataUrl;scanState.data=null;
          drawPanel();
          toast("📸 Foto capturada","success");
        };
      }catch(err){
        toast("⚠️ No se pudo acceder a la cámara","error");
      }
    };

    document.getElementById("btnScanAn").onclick=async()=>{
      if(!scanState.file&&!scanState.url)return;
      scanState.loading=true;drawPanel();
      try{
        const b64=scanState.url.split(",")[1];
        const mt=scanState.file?.type||"image/jpeg";
        const data=await scanFoodImage(b64,mt,plan);
        scanState.data=data;scanState.loading=false;
        // save to history
        const fresh=db.getCurrent();
        const hh=db.getScanHistory();
        hh.unshift({id:Date.now(),userEmail:fresh.email,date:new Date().toLocaleString("es",{day:"2-digit",month:"short",hour:"2-digit",minute:"2-digit"}),thumb:scanState.url,...data});
        if(hh.length>20)hh.splice(20);
        db.saveScanHistory(hh);
        fresh.scanCount=(fresh.scanCount||0)+1;
        addPoints(fresh,5,true);checkAchievements(fresh);

        // Save to daily calorie log
        addDailyFoodEntry(fresh.email,{
          foodName:data.foodName,
          totalCalories:data.totalCalories||0,
          thumb:scanState.url,
          dietScore:data.dietScore,
          macros:data.macros
        });

        // Check calorie limit after adding
        const newTotal=getTodayCalories(fresh.email);
        const calLimit=getCalorieLimit(plan);
        if(newTotal>calLimit){
          toast(`⚠️ ¡Cuidado! Con esta comida llegas a ${newTotal} kcal (límite: ${calLimit} kcal)`,"error");
        }else if(newTotal>=calLimit*0.8){
          toast(`⚡ Atención: llevas ${newTotal} kcal de ${calLimit} kcal (${Math.round(newTotal/calLimit*100)}%)`,"warn");
        }

        toast("✅ Análisis completado. +5 pts");
        drawPanel();
      }catch(err){
        scanState.loading=false;
        scanState.data={error:"No se pudo analizar. Intenta con otra foto más clara."};
        drawPanel();
      }
    };
    if(document.getElementById("btnClearHist")){
      document.getElementById("btnClearHist").onclick=()=>{
        if(!confirm("¿Borrar historial?"))return;
        const all=db.getScanHistory().filter(h=>h.userEmail!==u.email);
        db.saveScanHistory(all);toast("Historial borrado","warn");drawPanel();
      };
    }
    document.querySelectorAll(".hist-row").forEach(row=>{
      row.onclick=()=>{
        const entry=db.getScanHistory().find(h=>h.id===parseInt(row.dataset.id));
        if(!entry)return;
        scanState.url=entry.thumb;scanState.data=entry;scanState.file={};
        drawPanel();window.scrollTo({top:0,behavior:"smooth"});
      };
    });
  };
  drawPanel();
}

