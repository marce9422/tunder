          </div>
        </div>
        <div class="workout-day-body ${workoutOpen[idx]?'open':''}" id="wbody_${idx}">
          ${dia.ejercicios.map((ej,ei)=>{
            const done=doneSets.includes(ei);
            return`<div class="exercise-row">
              <div class="exercise-icon">${ej.icon}</div>
              <div class="exercise-info">
                <div class="exercise-name" style="${done?'text-decoration:line-through;color:var(--text2);':''}">${ej.name}</div>
                <div class="exercise-sets">${ej.sets}</div>
                <div class="exercise-tip">${ej.tip}</div>
              </div>
              <button class="done-btn ${done?'done':''}" onclick="toggleExercise(${idx},${ei})">
                ${done?'✅ Hecho':'Marcar'}
              </button>
            </div>`;
          }).join("")}
          <div style="margin-top:10px;">
            <div class="progress-bar"><div class="progress-fill" style="width:${doneSets.length/dia.ejercicios.length*100}%;"></div></div>
            <div style="font-size:11px;color:var(--text2);margin-top:4px;">${doneSets.length}/${dia.ejercicios.length} ejercicios</div>
          </div>
        </div>
      </div>`;
    }).join("")}
  </div>`;

  // make functions global for onclick
  window.toggleWorkout=(idx)=>{
    workoutOpen[idx]=!workoutOpen[idx];
    document.getElementById(`wbody_${idx}`).classList.toggle("open",workoutOpen[idx]);
    document.getElementById(`wchev_${idx}`).style.transform=workoutOpen[idx]?"rotate(180deg)":"";
  };
  window.toggleExercise=(dIdx,eIdx)=>{
    const fresh=db.getCurrent();
    const hh=new Date().toISOString().slice(0,10);
    if(!fresh.ejerciciosDone)fresh.ejerciciosDone={};
    const key=`${hh}_${dIdx}`;
    if(!fresh.ejerciciosDone[key])fresh.ejerciciosDone[key]=[];
    const arr=fresh.ejerciciosDone[key];
    const pos=arr.indexOf(eIdx);
    if(pos===-1){arr.push(eIdx);toast("💪 ¡Ejercicio completado! +2 pts");addPoints(fresh,2,true);}
    else{arr.splice(pos,1);}
    saveUser(fresh);
    renderEntrenos(document.getElementById("tabPanel"),db.getCurrent(),plan);
  };

  // auto-open today
  if(!workoutOpen[todayRutinaIdx]&&document.getElementById(`wbody_${todayRutinaIdx}`)){
    workoutOpen[todayRutinaIdx]=true;
    document.getElementById(`wbody_${todayRutinaIdx}`).classList.add("open");
    document.getElementById(`wchev_${todayRutinaIdx}`).style.transform="rotate(180deg)";
  }
}

