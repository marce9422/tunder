function calcularMetasPeso(plan){
  const{peso,objetivo}=plan;
  const meses=[];
  for(let m=1;m<=6;m++){
    let meta;
    if(objetivo==="fat_loss"){
      meta=+(peso-(m*2.5)).toFixed(1);
      if(meta<45)meta=45;
    } else {
      meta=+(peso+(m*1.2)).toFixed(1);
    }
    const fecha=new Date();fecha.setMonth(fecha.getMonth()+m);
    meses.push({mes:fecha.toLocaleDateString("es",{month:"long",year:"numeric"}),peso:meta,num:m});
  }
  return meses;
}

