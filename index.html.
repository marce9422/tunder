      ${calBannerHTML}
      <div class="calorie-bar-summary">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;">
          <span style="font-size:13px;font-weight:700;">Consumido hoy</span>
          <span style="font-size:13px;font-weight:800;color:${pct>=1?'var(--danger)':pct>=0.8?'var(--warn)':'var(--accent)'};">${consumed} / ${limit} kcal</span>
        </div>
        <div class="progress-bar"><div class="progress-fill" style="width:${Math.min(100,pct*100)}%;background:${pct>=1?'var(--danger)':pct>=0.8?'var(--warn)':'linear-gradient(90deg,var(--accent),var(--accent2))'};"></div></div>
      </div>

      <div class="scanner-layout">
        <!-- LEFT: upload -->
        <div>
          <div class="scanner-drop ${scanState.url?'has-img':''}" id="scanDrop">
            ${scanState.url
              ?`<img src="${scanState.url}" id="scanImg">`
              :`<div style="font-size:36px;margin-bottom:10px;">🍽️</div>
                <p style="font-size:14px;color:var(--text2);">Toca para subir foto de tu comida</p>
                <p style="font-size:12px;color:var(--text3);margin-top:4px;">JPG, PNG, WEBP</p>`}
          </div>
          <div style="display:flex;gap:8px;margin-top:10px;">
            <button class="btn btn-secondary btn-sm" id="btnScanUp" style="flex:1;"><i class="fas fa-upload"></i> Subir</button>
            <button class="btn btn-secondary btn-sm" id="btnCamera" style="flex:1;"><i class="fas fa-camera"></i> Cámara</button>
            <button class="btn btn-primary btn-sm" id="btnScanAn" style="flex:1;" ${!scanState.url||scanState.loading?'disabled':''}>
              ${scanState.loading?'<span style="font-size:11px;">Analizando…</span>':'<i class="fas fa-search"></i> Analizar'}
            </button>
            <button class="btn btn-secondary btn-sm" id="btnScanReset"><i class="fas fa-redo"></i></button>
          </div>
          ${scanState.loading?`<div style="text-align:center;margin-top:14px;"><div style="width:40px;height:40px;border:3px solid var(--border2);border-top:3px solid var(--accent);border-radius:50%;animation:spin 1s linear infinite;margin:0 auto 8px;"></div><p style="font-size:12px;color:var(--text2);">Analizando con IA…</p></div>`:''}
