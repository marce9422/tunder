function buildPlateSVG(aRatio,eRatio){
  const r=90;const cx=100;const cy=100;
  const aAngle=aRatio/100*360;
  const eAngle=eRatio/100*360;
  function sector(startDeg,endDeg,color,label,labelR){
    const s=startDeg*Math.PI/180;const e=endDeg*Math.PI/180;
    const x1=cx+r*Math.sin(s);const y1=cy-r*Math.cos(s);
    const x2=cx+r*Math.sin(e);const y2=cy-r*Math.cos(e);
    const large=endDeg-startDeg>180?1:0;
    const mid=(startDeg+endDeg)/2*Math.PI/180;
    const lx=cx+(r*0.62)*Math.sin(mid);const ly=cy-(r*0.62)*Math.cos(mid);
    return`<path d="M${cx},${cy} L${x1},${y1} A${r},${r} 0 ${large},1 ${x2},${y2} Z" fill="${color}" opacity="0.92"/>
    <text x="${lx}" y="${ly}" text-anchor="middle" dominant-baseline="middle" font-size="11" font-weight="700" fill="#0b0f14">${label}</text>`;
  }
  return`<svg width="200" height="200" viewBox="0 0 200 200">
    <circle cx="100" cy="100" r="95" fill="#1a2232" stroke="#232f42" stroke-width="2"/>
    ${sector(0,aAngle,"#00e5a0","Tipo A\n${aRatio}%",60)}
    ${sector(aAngle,360,"#f0b429","Tipo E\n${eRatio}%",60)}
    <circle cx="100" cy="100" r="32" fill="#0b0f14"/>
    <text x="100" y="97" text-anchor="middle" font-size="10" fill="#7a90a8" font-family="DM Sans">Tu</text>
    <text x="100" y="109" text-anchor="middle" font-size="10" fill="#7a90a8" font-family="DM Sans">plato</text>
    <circle cx="100" cy="100" r="95" fill="none" stroke="#232f42" stroke-width="1.5"/>
  </svg>`.replace("${aRatio}",aRatio).replace("${eRatio}",eRatio);
}

