<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Metabolismo Activo</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&family=Orbitron:wght@400;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
:root{
  --bg:#0b0f14;--surface:#131920;--surface2:#1a2232;--surface3:#1f2b3f;
  --border:#232f42;--border2:#2d3f5a;
  --accent:#00e5a0;--accent2:#00b8d9;--accent3:#ff6b35;--accent4:#a78bfa;
  --text:#e2eaf4;--text2:#7a90a8;--text3:#4a6070;
  --danger:#f85149;--warn:#f0b429;--success:#3fb950;
  --r:14px;--shadow:0 8px 40px rgba(0,0,0,.55);
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden}
body::before{content:'';position:fixed;inset:0;background:
  radial-gradient(ellipse 70% 50% at 5% 0%,rgba(0,229,160,.06) 0%,transparent 60%),
  radial-gradient(ellipse 50% 40% at 95% 100%,rgba(0,184,217,.06) 0%,transparent 60%);
  pointer-events:none;z-index:0}
#app{position:relative;z-index:1;max-width:980px;margin:0 auto;padding:14px}

/* ── INPUTS ── */
input,select,textarea{background:var(--surface2);border:1px solid var(--border);border-radius:9px;color:var(--text);padding:10px 14px;font-family:'DM Sans',sans-serif;font-size:14px;width:100%;outline:none;transition:border-color .2s}
input:focus,select:focus,textarea:focus{border-color:var(--accent);box-shadow:0 0 0 2px rgba(0,229,160,.12)}
select option{background:var(--surface2)}
::placeholder{color:var(--text3)}

/* ── BUTTONS ── */
.btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;padding:10px 20px;border-radius:9px;font-family:'DM Sans',sans-serif;font-weight:600;font-size:14px;cursor:pointer;border:none;transition:all .18s;text-decoration:none;white-space:nowrap}
.btn-primary{background:var(--accent);color:#0b0f14}
.btn-primary:hover{background:#00c987;transform:translateY(-1px)}
.btn-secondary{background:var(--surface2);color:var(--text);border:1px solid var(--border)}
.btn-secondary:hover{border-color:var(--accent);color:var(--accent)}
.btn-danger{background:var(--danger);color:#fff}
.btn-warn{background:var(--warn);color:#0b0f14}
.btn-blue{background:var(--accent2);color:#0b0f14}
.btn-purple{background:var(--accent4);color:#0b0f14}
.btn-full{width:100%}
.btn-sm{padding:7px 13px;font-size:13px}
.btn:disabled{opacity:.45;cursor:not-allowed;transform:none!important}

/* ── CARDS ── */
.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);box-shadow:var(--shadow)}

/* ── BADGES ── */
.badge{display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:99px;font-size:11px;font-weight:700}
.badge-green{background:rgba(0,229,160,.13);color:var(--accent)}
.badge-blue{background:rgba(0,184,217,.13);color:var(--accent2)}
.badge-orange{background:rgba(255,107,53,.13);color:var(--accent3)}
.badge-yellow{background:rgba(240,180,41,.13);color:var(--warn)}
.badge-purple{background:rgba(167,139,250,.13);color:var(--accent4)}

/* ── AUTH ── */
.auth-wrap{max-width:440px;margin:36px auto;padding:0 8px}
.auth-logo{text-align:center;margin-bottom:28px}
.auth-logo .logo-icon{width:70px;height:70px;background:linear-gradient(135deg,var(--accent),var(--accent2));border-radius:20px;display:flex;align-items:center;justify-content:center;font-size:30px;margin:0 auto 14px;box-shadow:0 0 40px rgba(0,229,160,.28)}
.tabs-auth{display:flex;background:var(--surface2);border-radius:10px;padding:4px;margin-bottom:20px}
.tab-auth-btn{flex:1;padding:9px;border-radius:7px;border:none;background:transparent;color:var(--text2);font-family:'DM Sans',sans-serif;font-weight:600;font-size:14px;cursor:pointer;transition:all .2s}
.tab-auth-btn.active{background:var(--accent);color:#0b0f14}
.form-group{margin-bottom:14px}
.form-label{display:block;font-weight:600;font-size:13px;margin-bottom:6px}

/* ── TOPBAR ── */
.topbar{display:flex;align-items:center;justify-content:space-between;padding:10px 0 16px;flex-wrap:wrap;gap:10px}
.topbar-logo{display:flex;align-items:center;gap:10px}
.topbar-logo .icon{width:36px;height:36px;background:linear-gradient(135deg,var(--accent),var(--accent2));border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px}
.topbar-logo span{font-family:'Syne',sans-serif;font-weight:800;font-size:18px;background:linear-gradient(90deg,var(--accent),var(--accent2));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.points-chip{display:flex;align-items:center;gap:6px;background:rgba(240,180,41,.11);border:1px solid rgba(240,180,41,.22);border-radius:99px;padding:6px 13px;font-weight:700;color:var(--warn);font-size:14px}

/* ── NAV ── */
.bottom-nav{display:flex;background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:5px;gap:3px;margin-bottom:14px;overflow-x:auto;scrollbar-width:none}
.bottom-nav::-webkit-scrollbar{display:none}
.nav-btn{flex:1;min-width:62px;display:flex;flex-direction:column;align-items:center;gap:3px;padding:8px 4px;border-radius:10px;border:none;background:transparent;color:var(--text2);font-family:'DM Sans',sans-serif;font-size:10px;font-weight:600;cursor:pointer;transition:all .18s;white-space:nowrap}
.nav-btn i{font-size:17px}
.nav-btn.active{background:linear-gradient(135deg,rgba(0,229,160,.14),rgba(0,184,217,.14));color:var(--accent);border:1px solid rgba(0,229,160,.28)}

/* ── TAB PANEL ── */
.tab-panel{animation:fadeUp .22s ease}
@keyframes fadeUp{from{opacity:0;transform:translateY(7px)}to{opacity:1;transform:none}}

/* ── STAT GRID ── */
.stat-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:11px}
.stat-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:15px;text-align:center;transition:border-color .2s}
.stat-card:hover{border-color:var(--accent)}
.stat-icon{font-size:22px;margin-bottom:5px}
.stat-label{font-size:11px;color:var(--text2);font-weight:700;text-transform:uppercase;letter-spacing:.5px}
.stat-value{font-family:'Syne',sans-serif;font-size:26px;font-weight:800;color:var(--accent)}
.stat-unit{font-size:11px;color:var(--text3)}

/* ── INFO BOXES ── */
.info-box{border-radius:var(--r);padding:15px;border-left:3px solid;margin-bottom:11px;font-size:14px;line-height:1.65}
.info-box h4{font-family:'Syne',sans-serif;font-weight:700;margin-bottom:7px;font-size:15px}
.info-box ul{padding-left:17px;margin-top:5px}
.info-box li{margin-bottom:3px}
.info-box.green{background:rgba(63,185,80,.07);border-color:var(--success)}
.info-box.blue{background:rgba(0,184,217,.07);border-color:var(--accent2)}
.info-box.orange{background:rgba(255,107,53,.07);border-color:var(--accent3)}
.info-box.yellow{background:rgba(240,180,41,.07);border-color:var(--warn)}
.info-box.purple{background:rgba(167,139,250,.07);border-color:var(--accent4)}
.info-box.gray{background:rgba(139,148,158,.06);border-color:var(--border2)}

/* ── WATER ── */
.water-glasses{display:flex;flex-wrap:wrap;gap:7px;margin-top:9px}
.glass-btn{width:38px;height:38px;border-radius:8px;border:2px solid var(--border);background:transparent;font-size:18px;cursor:pointer;transition:all .18s;display:flex;align-items:center;justify-content:center}
.glass-btn.filled{background:rgba(0,184,217,.18);border-color:var(--accent2)}
.glass-btn:hover{border-color:var(--accent2);transform:scale(1.12)}

/* ── CHAT ── */
.chat-box{background:var(--surface2);border:1px solid var(--border);border-radius:var(--r);height:370px;overflow-y:auto;padding:14px;display:flex;flex-direction:column;gap:9px;scroll-behavior:smooth}
.chat-box::-webkit-scrollbar{width:4px}
.chat-box::-webkit-scrollbar-thumb{background:var(--border);border-radius:99px}
.msg-wrap{display:flex;gap:7px;max-width:88%}
.msg-wrap.user{margin-left:auto;flex-direction:row-reverse}
.msg-avatar{width:30px;height:30px;min-width:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px}
.msg-avatar.bot{background:linear-gradient(135deg,var(--accent),var(--accent2));color:#0b0f14}
.msg-avatar.user{background:var(--surface);border:1px solid var(--border)}
.msg-bubble{padding:10px 13px;border-radius:11px;font-size:13.5px;line-height:1.6}
.msg-bubble.bot{background:var(--surface);border:1px solid var(--border)}
.msg-bubble.user{background:linear-gradient(135deg,rgba(0,229,160,.18),rgba(0,184,217,.18));border:1px solid rgba(0,229,160,.28)}
.typing-dots{display:flex;gap:4px;align-items:center;padding:3px 0}
.typing-dots span{width:7px;height:7px;background:var(--text2);border-radius:50%;animation:bounce 1.2s infinite}
.typing-dots span:nth-child(2){animation-delay:.2s}
.typing-dots span:nth-child(3){animation-delay:.4s}
@keyframes bounce{0%,80%,100%{transform:translateY(0)}40%{transform:translateY(-6px)}}
.chat-input-row{display:flex;gap:8px;margin-top:9px}
.chat-input-row input{flex:1}

/* ── PROGRESS ── */
.progress-bar{height:6px;background:var(--surface2);border-radius:99px;overflow:hidden;margin-top:4px}
.progress-fill{height:100%;border-radius:99px;background:linear-gradient(90deg,var(--accent),var(--accent2));transition:width .5s}

/* ── SECTION TITLE ── */
.section-title{font-family:'Syne',sans-serif;font-size:19px;font-weight:800;margin-bottom:14px;display:flex;align-items:center;gap:8px}

/* ── TOAST ── */
.toast{position:fixed;bottom:22px;left:50%;transform:translateX(-50%) translateY(80px);background:var(--surface2);border:1px solid var(--border);border-radius:10px;padding:11px 20px;font-size:14px;font-weight:600;box-shadow:var(--shadow);transition:transform .3s;z-index:9999;white-space:nowrap}
.toast.show{transform:translateX(-50%) translateY(0)}
.toast.success{border-color:var(--success);color:var(--success)}
.toast.warn{border-color:var(--warn);color:var(--warn)}
.toast.error{border-color:var(--danger);color:var(--danger)}

/* ── CUESTIONARIO ── */
.option-cards{display:grid;grid-template-columns:1fr 1fr;gap:9px}
.option-card{background:var(--surface2);border:2px solid var(--border);border-radius:11px;padding:13px;cursor:pointer;transition:all .18s;text-align:center}
.option-card:hover{border-color:var(--accent)}
.option-card.selected{border-color:var(--accent);background:rgba(0,229,160,.09)}
.option-card .opt-icon{font-size:26px;margin-bottom:5px}
.option-card .opt-label{font-weight:700;font-size:13px}
.option-card .opt-desc{font-size:11px;color:var(--text2);margin-top:3px}
.divider{height:1px;background:var(--border);margin:18px 0}

/* ── PLATE VIZ ── */
.plate-wrap{display:flex;flex-direction:column;align-items:center;gap:16px;padding:20px 0}
.plate-svg-wrap{position:relative;width:220px;height:220px}
.plate-legend{display:flex;flex-direction:column;gap:8px;width:100%}
.legend-row{display:flex;align-items:center;gap:10px;font-size:13px}
.legend-dot{width:13px;height:13px;border-radius:4px;flex-shrink:0}

/* ── SCANNER ── */
.scanner-layout{display:grid;grid-template-columns:1fr 1fr;gap:14px}
@media(max-width:640px){.scanner-layout{grid-template-columns:1fr}}
.scanner-drop{border:2px dashed var(--border2);border-radius:var(--r);padding:30px;text-align:center;cursor:pointer;transition:all .2s;background:var(--surface2)}
.scanner-drop:hover{border-color:var(--accent);background:rgba(0,229,160,.04)}
.scanner-drop.has-img{border-style:solid;border-color:var(--accent);padding:8px}
.scanner-drop img{width:100%;border-radius:9px;max-height:220px;object-fit:cover}
.scanner-results{display:flex;flex-direction:column;gap:11px}
.score-circle{width:54px;height:54px;border-radius:50%;display:flex;flex-direction:column;align-items:center;justify-content:center;flex-shrink:0;font-family:'Orbitron',sans-serif}
.score-num{font-size:19px;font-weight:700;line-height:1}
.score-of{font-size:9px;opacity:.7}
.score-high{background:rgba(0,229,160,.12);border:1.5px solid rgba(0,229,160,.4);color:var(--accent)}
.score-mid{background:rgba(240,180,41,.12);border:1.5px solid rgba(240,180,41,.4);color:var(--warn)}
.score-low{background:rgba(248,81,73,.12);border:1.5px solid rgba(248,81,73,.4);color:var(--danger)}
.macro-bar-row{margin-bottom:9px}
.macro-label-row{display:flex;justify-content:space-between;font-size:12px;color:var(--text2);margin-bottom:3px}
.history-thumb{width:44px;height:44px;border-radius:8px;object-fit:cover;border:1px solid var(--border);flex-shrink:0}

/* ── WORKOUTS ── */
.workout-day-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);overflow:hidden;margin-bottom:11px;transition:border-color .2s}
.workout-day-card:hover{border-color:var(--accent2)}
.workout-day-header{padding:13px 16px;display:flex;align-items:center;justify-content:space-between;cursor:pointer;user-select:none}
.workout-day-title{font-family:'Syne',sans-serif;font-weight:700;font-size:15px;display:flex;align-items:center;gap:8px}
.workout-day-body{padding:0 16px 14px;display:none}
.workout-day-body.open{display:block}
.exercise-row{display:flex;align-items:center;gap:12px;padding:9px 0;border-bottom:1px solid var(--border)}
.exercise-row:last-child{border-bottom:none}
.exercise-icon{font-size:22px;min-width:28px;text-align:center}
.exercise-info{flex:1}
.exercise-name{font-weight:600;font-size:14px}
.exercise-sets{font-size:12px;color:var(--text2);margin-top:2px}
.exercise-tip{font-size:11px;color:var(--accent);margin-top:2px;font-style:italic}
.done-btn{padding:5px 11px;border-radius:7px;font-size:12px;font-weight:700;cursor:pointer;border:1px solid var(--border);background:transparent;color:var(--text2);transition:all .18s}
.done-btn.done{background:rgba(0,229,160,.15);border-color:var(--accent);color:var(--accent)}

/* ── MENTE ── */
.meditation-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:12px}
.meditation-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);overflow:hidden;cursor:pointer;transition:all .2s}
.meditation-card:hover{border-color:var(--accent4);transform:translateY(-2px)}
.meditation-thumb{width:100%;height:110px;display:flex;align-items:center;justify-content:center;font-size:42px;background:linear-gradient(135deg,var(--surface2),var(--surface3))}
.meditation-info{padding:12px}
.meditation-title{font-weight:700;font-size:14px;margin-bottom:3px}
.meditation-sub{font-size:12px;color:var(--text2)}
.meditation-duration{font-size:11px;color:var(--accent4);margin-top:4px;font-weight:700}

/* ── PERFIL / LOGROS ── */
.profile-stat{display:flex;justify-content:space-between;padding:11px 0;border-bottom:1px solid var(--border);font-size:14px}
.profile-stat:last-child{border-bottom:none}
.profile-stat .label{color:var(--text2)}
.profile-stat .val{font-weight:600}
.achievement{display:flex;align-items:center;gap:12px;padding:11px;border-radius:10px;margin-bottom:8px;border:1px solid var(--border);transition:all .2s}
.achievement.unlocked{background:rgba(0,229,160,.06);border-color:rgba(0,229,160,.25)}
.achievement.locked{background:var(--surface2);opacity:.55;filter:grayscale(.8)}
.achievement-icon{font-size:28px;min-width:36px;text-align:center}
.achievement-name{font-weight:700;font-size:14px}
.achievement-desc{font-size:12px;color:var(--text2);margin-top:2px}
.peso-meta-row{display:flex;align-items:center;gap:10px;padding:10px 0;border-bottom:1px solid var(--border);font-size:13px}
.peso-meta-row:last-child{border-bottom:none}
.peso-meta-month{min-width:70px;color:var(--text2);font-weight:600}
.peso-meta-val{font-weight:800;color:var(--accent);font-family:'Syne',sans-serif;font-size:16px}
.peso-meta-badge{margin-left:auto}
.photos-grid{display:flex;flex-wrap:wrap;gap:9px;margin-top:9px}
.photos-grid img{width:88px;height:88px;object-fit:cover;border-radius:9px;border:2px solid var(--border);transition:border-color .18s;cursor:pointer}
.photos-grid img:hover{border-color:var(--accent)}
.streak-days{display:flex;gap:4px;margin-top:7px}
.streak-day{width:28px;height:28px;border-radius:6px;font-size:11px;display:flex;align-items:center;justify-content:center;font-weight:700}
.streak-day.done{background:rgba(0,229,160,.18);color:var(--accent);border:1px solid rgba(0,229,160,.35)}
.streak-day.empty{background:var(--surface2);color:var(--text2);border:1px solid var(--border)}

/* ── MODAL ── */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:500;display:flex;align-items:center;justify-content:center;padding:16px}
.modal-box{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:24px;max-width:440px;width:100%;max-height:82vh;overflow-y:auto}

/* ── VIDEO EMBED ── */
.video-thumb-wrap{position:relative;width:100%;padding-top:56.25%;border-radius:10px;overflow:hidden;background:#000;cursor:pointer}
.video-thumb-wrap img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover}
.video-play-btn{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,.35)}
.video-play-btn i{font-size:44px;color:#fff;text-shadow:0 2px 12px rgba(0,0,0,.6)}
.iframe-wrap{position:relative;padding-top:56.25%;border-radius:10px;overflow:hidden}
.iframe-wrap iframe{position:absolute;inset:0;width:100%;height:100%;border:none}

/* ── SCROLL ── */
.scroll-list{max-height:240px;overflow-y:auto;scrollbar-width:thin;scrollbar-color:var(--border) transparent}
.scroll-list::-webkit-scrollbar{width:4px}
.scroll-list::-webkit-scrollbar-thumb{background:var(--border);border-radius:99px}

/* ── TIENDA ── */
.product-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:18px;transition:all .2s}
.product-card:hover{border-color:var(--accent);transform:translateY(-2px)}
.product-price{font-size:20px;font-weight:800;color:var(--accent);font-family:'Syne',sans-serif}

/* ── CALORIE TRACKER ── */
.calorie-ring-wrap{position:relative;width:140px;height:140px;margin:0 auto}
.calorie-ring-text{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center}
.calorie-ring-val{font-family:'Syne',sans-serif;font-size:28px;font-weight:800}
.calorie-ring-label{font-size:11px;color:var(--text2)}
.calorie-alert{background:rgba(248,81,73,.08);border:1px solid rgba(248,81,73,.3);border-radius:var(--r);padding:12px 16px;display:flex;align-items:center;gap:10px;font-size:13px;color:var(--danger);animation:pulseAlert 2s infinite}
@keyframes pulseAlert{0%,100%{border-color:rgba(248,81,73,.3)}50%{border-color:rgba(248,81,73,.7)}}
.calorie-warn{background:rgba(240,180,41,.08);border:1px solid rgba(240,180,41,.3);border-radius:var(--r);padding:10px 14px;display:flex;align-items:center;gap:8px;font-size:13px;color:var(--warn)}
.calorie-entry{display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid var(--border)}
.calorie-entry:last-child{border-bottom:none}
.calorie-entry-thumb{width:36px;height:36px;border-radius:7px;object-fit:cover;border:1px solid var(--border)}
.calorie-bar-summary{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:14px;margin-bottom:12px}
.calorie-history-chart{display:flex;align-items:flex-end;gap:6px;height:120px;padding:10px 0}
.calorie-history-bar{flex:1;border-radius:4px 4px 0 0;min-width:20px;position:relative;transition:height .3s}
.calorie-history-bar .bar-label{position:absolute;bottom:-18px;left:50%;transform:translateX(-50%);font-size:10px;color:var(--text3);white-space:nowrap}
.calorie-history-bar .bar-value{position:absolute;top:-16px;left:50%;transform:translateX(-50%);font-size:9px;font-weight:700;color:var(--text2)}

/* ── CAMERA MODAL ── */
.camera-modal{position:fixed;inset:0;background:rgba(0,0,0,.92);z-index:600;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:16px}
.camera-modal video{width:100%;max-width:480px;border-radius:14px;background:#000}
.camera-modal .camera-controls{display:flex;gap:12px;margin-top:16px}
