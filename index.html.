      if(step<stepCount){step++;draw();}
      else{
        const imc=+(datos.peso/((datos.altura/100)**2)).toFixed(1);
        const aguaDiaria=datos.objetivo==="fat_loss"?Math.floor(datos.peso/7):Math.floor(datos.peso/8);
        u.plan={...datos,imc,aguaDiaria};
        u.cuestionarioCompleto=true;
        saveUser(u);checkAchievements(u);
        toast("🎉 ¡Plan generado!");
        renderApp();
      }
    };
  };
  draw();
}

