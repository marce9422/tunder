      <div class="form-group"><label class="form-label">Peso actual (kg)</label><input type="number" id="ip" value="${datos.peso}" placeholder="Ej: 75" min="30" max="250"></div>
      <div class="form-group"><label class="form-label">Altura (cm)</label><input type="number" id="ia" value="${datos.altura}" placeholder="Ej: 170" min="100" max="230"></div>`,
      ()=>`<div class="section-title">🧠 Tipo de metabolismo</div>
      <div class="info-box blue" style="font-size:13px;margin-bottom:13px;">Tu sistema nervioso determina qué alimentos te funcionan mejor.</div>
      <div class="option-cards">
        <div class="option-card ${datos.sistema==='Pasivo'?'selected':''}" data-sis="Pasivo"><div class="opt-icon">🟢</div><div class="opt-label">Pasivo / Lento</div><div class="opt-desc">Frío, cansancio, digestión lenta</div></div>
        <div class="option-card ${datos.sistema==='Excitado'?'selected':''}" data-sis="Excitado"><div class="opt-icon">🔵</div><div class="opt-label">Excitado / Activo</div><div class="opt-desc">Ansiedad, insomnio, estrés</div></div>
      </div>`,
      ()=>`<div class="section-title">🦠 ¿Síntomas de Cándida?</div>
      <div class="info-box yellow" style="font-size:13px;margin-bottom:13px;"><strong>Síntomas:</strong> antojos de dulce, hinchazón, niebla mental, fatiga, infecciones frecuentes.</div>
      <div class="option-cards">
        <div class="option-card ${datos.candida==='no'?'selected':''}" data-can="no"><div class="opt-icon">✅</div><div class="opt-label">No, sin síntomas</div></div>
        <div class="option-card ${datos.candida==='si'?'selected':''}" data-can="si"><div class="opt-icon">⚠️</div><div class="opt-label">Sí, tengo síntomas</div></div>
      </div>`
    ];
    app.innerHTML=`
    <div style="max-width:540px;margin:28px auto;">
      <div style="text-align:center;margin-bottom:20px;">
        <div class="topbar-logo" style="justify-content:center;"><div class="icon">⚡</div><span>Metabolismo Activo</span></div>
        <p style="color:var(--text2);margin-top:7px;font-size:13px;">Paso ${step} de ${stepCount} — Configura tu plan</p>
        <div class="progress-bar" style="margin:10px auto 0;max-width:280px;"><div class="progress-fill" style="width:${step/stepCount*100}%"></div></div>
      </div>
      <div class="card" style="padding:22px;">
        <div id="stepContent">${steps[step-1]()}</div>
        <div style="display:flex;gap:9px;margin-top:18px;">
          ${step>1?`<button class="btn btn-secondary" id="bprev">← Atrás</button>`:''}
          <button class="btn btn-primary" id="bnext" style="flex:1;">${step===stepCount?'🎯 Generar mi plan':'Siguiente →'}</button>
        </div>
      </div>
    </div>`;
    document.querySelectorAll("[data-obj]").forEach(el=>el.onclick=()=>{datos.objetivo=el.dataset.obj;draw()});
    document.querySelectorAll("[data-sis]").forEach(el=>el.onclick=()=>{datos.sistema=el.dataset.sis;draw()});
    document.querySelectorAll("[data-can]").forEach(el=>el.onclick=()=>{datos.candida=el.dataset.can;draw()});
    if(step>1)document.getElementById("bprev").onclick=()=>{
      if(step===2){datos.peso=document.getElementById("ip")?.value||datos.peso;datos.altura=document.getElementById("ia")?.value||datos.altura;}
      step--;draw();
    };
    document.getElementById("bnext").onclick=()=>{
      if(step===2){
        datos.peso=parseFloat(document.getElementById("ip").value);
        datos.altura=parseFloat(document.getElementById("ia").value);
        if(!datos.peso||datos.peso<30||!datos.altura||datos.altura<100){toast("⚠️ Ingresa peso y altura válidos","warn");return;}
