function getDailyFoodLog(userEmail){
  const today=new Date().toISOString().slice(0,10);
  const all=JSON.parse(localStorage.getItem("ma_daily_calories")||"{}");
  return (all[today]||[]).filter(e=>e.userEmail===userEmail);
}

function addDailyFoodEntry(userEmail,entry){
  const today=new Date().toISOString().slice(0,10);
  const all=JSON.parse(localStorage.getItem("ma_daily_calories")||"{}");
  if(!all[today])all[today]=[];
  all[today].push({id:Date.now(),userEmail,...entry,timestamp:new Date().toISOString()});
  localStorage.setItem("ma_daily_calories",JSON.stringify(all));
}

function getTodayCalories(userEmail){
  return getDailyFoodLog(userEmail).reduce((sum,e)=>sum+(e.totalCalories||0),0);
}

function getCalorieLimit(plan){
  const adminRaw=localStorage.getItem("ma_admin_config");
  if(adminRaw){
    try{
      const admin=JSON.parse(adminRaw);
      if(admin.calorieLimitFatLoss&&plan.objetivo==="fat_loss")return admin.calorieLimitFatLoss;
      if(admin.calorieLimitMuscleGain&&plan.objetivo==="muscle_gain")return admin.calorieLimitMuscleGain;
    }catch(e){}
  }
  const peso=plan.peso||70;
  let bmr;
  if(plan.objetivo==="fat_loss"){
    bmr=(10*peso+6.25*170-5*30+5)*1.3-500;
  }else{
    bmr=(10*peso+6.25*170-5*30+5)*1.3+300;
  }
  return Math.round(bmr);
}

function getCalorieHistory(userEmail,days){
  const logs=JSON.parse(localStorage.getItem("ma_daily_calories")||"{}");
  const result=[];
  const today=new Date();
  for(let i=0;i<days;i++){
    const d=new Date(today);
    d.setDate(d.getDate()-i);
    const key=d.toISOString().slice(0,10);
    const entries=(logs[key]||[]).filter(e=>e.userEmail===userEmail);
    const total=entries.reduce((s,e)=>s+(e.totalCalories||0),0);
    result.push({date:key,label:d.toLocaleDateString("es",{day:"2-digit",month:"short"}),total,entries});
  }
  return result;
}

function buildCalorieRing(consumed,limit){
  const pct=Math.min(consumed/limit,1.3);
  const displayPct=Math.min(pct,1);
  const circumference=2*Math.PI*58;
  const filled=circumference*displayPct;
  const color=pct>=1?'var(--danger)':pct>=0.8?'var(--warn)':'var(--accent)';
  const remaining=Math.max(0,limit-consumed);
  return `
    <div class="calorie-ring-wrap">
      <svg width="140" height="140" viewBox="0 0 140 140">
        <circle cx="70" cy="70" r="58" fill="none" stroke="var(--surface3)" stroke-width="10"/>
        <circle cx="70" cy="70" r="58" fill="none" stroke="${color}" stroke-width="10"
          stroke-dasharray="${circumference}" stroke-dashoffset="${circumference-filled}"
          stroke-linecap="round" transform="rotate(-90 70 70)" style="transition:stroke-dashoffset .6s"/>
      </svg>
      <div class="calorie-ring-text">
        <div class="calorie-ring-val" style="color:${color}">${consumed}</div>
        <div class="calorie-ring-label">de ${limit} kcal</div>
      </div>
    </div>
    <div style="text-align:center;margin-top:8px;font-size:13px;color:var(--text2);">
      ${pct>=1?`<span style="color:var(--danger);font-weight:700;">¡Excedido por ${consumed-limit} kcal!</span>`:`Te quedan <span style="color:var(--accent);font-weight:700;">${remaining} kcal</span> disponibles`}
    </div>`;
}

