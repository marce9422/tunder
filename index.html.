/* ═══════════════════════════════════════════════════
   API GENÉRICA (compatible con cualquier proveedor)
═══════════════════════════════════════════════════ */
function getAuthHeader(apiKey,authType){
  switch(authType){
    case "Bearer": return {"Authorization":"Bearer "+apiKey};
    case "x-api-key": return {"x-api-key":apiKey,"anthropic-version":"2023-06-01"};
    default: return {"Authorization":authType+" "+apiKey};
  }
}

async function callClaude(messages,systemOverride){
  const apiKey=getApiKey();
  if(!apiKey){
    return "⚠️ API Key no configurada. Pide al administrador que la configure en el panel de administración.";
  }
  const config=getAdminConfig();
  const allMessages=[{role:"system",content:systemOverride||config.systemPrompt},...messages];
  const resp=await fetch(config.apiUrl,{
    method:"POST",
    headers:{
      "Content-Type":"application/json",
      ...getAuthHeader(apiKey,config.authType)
    },
    body:JSON.stringify({
      model:config.model,
      max_tokens:config.maxTokens,
      temperature:config.temperature,
      messages:allMessages
    })
  });
  const data=await resp.json();
  if(data.error){
    return "⚠️ Error de API: "+(data.error.message||JSON.stringify(data.error));
  }
  return data.choices?.[0]?.message?.content||"";
}

